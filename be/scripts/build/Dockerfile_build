# Need to package the code first `tar zcf be.tar.gz $(ls)` and move it to the same directory as Dokerfile

# Compile the go code, you can specify the golang version
FROM golang:1.23-alpine as build
COPY . /go/src/be
WORKDIR /go/src/be
RUN tar zxf be.tar.gz
RUN go env -w GOPROXY=https://goproxy.cn,direct
RUN go mod download
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /be cmd/be/main.go

# compressing binary files
#cd /
#upx -9 be


# building images with binary
FROM alpine:latest
MAINTAINER zhufuyi "g.zhufuyi@gmail.com"

# add curl, used for http service checking, can be installed without it if deployed in k8s
RUN apk add curl

COPY --from=build /be /app/be
COPY --from=build /go/src/be/configs/be.yml /app/configs/be.yml

# http port
EXPOSE 8080


WORKDIR /app

CMD ["./be", "-c", "configs/be.yml"]
# if you use the Configuration Center, be.yml is changed to the Configuration Center configuration.
